{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations": "6.0",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "rootDir": "src",
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "src/index.ts",
    "src/core/**/*.ts",
    "src/exports/**/*.ts",
    "src/monobank/**/*.ts",
    "src/privacy/**/*.ts",
    "src/server/**/*.ts",
    "src/sqlite/**/*.ts",
    "src/storage/**/*.ts",
    "src/sync/**/*.ts",
    "src/web/api.ts",
    "src/ui/**/*.ts"
  ]
}
