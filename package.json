{
  "name": "mono-ledger-sync",
  "version": "0.1.1",
  "description": "Local-first TypeScript app for syncing Monobank transactions into a private personal finance ledger.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./exports": {
      "types": "./dist/exports/index.d.ts",
      "import": "./dist/exports/index.js"
    },
    "./monobank": {
      "types": "./dist/monobank/index.d.ts",
      "import": "./dist/monobank/index.js"
    },
    "./privacy": {
      "types": "./dist/privacy/index.d.ts",
      "import": "./dist/privacy/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite/index.d.ts",
      "import": "./dist/sqlite/index.js"
    },
    "./sync": {
      "types": "./dist/sync/index.d.ts",
      "import": "./dist/sync/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist",
    "examples/sample-workflows",
    "fixtures/monobank",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "npm run build:lib && npm run build:web",
    "build:lib": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "clean": "rm -rf dist coverage",
    "coverage": "npm run build && node --test --experimental-test-coverage test/*.test.js",
    "dev": "npm run build && node dist/server/dev.js",
    "format": "prettier --check .",
    "lint": "npm run typecheck",
    "prepublishOnly": "npm run typecheck && npm test",
    "test": "npm run build && node --test test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "web:dev": "npm run build:lib && node dist/server/web-dev.js",
    "web:vite": "vite --host 127.0.0.1"
  },
  "keywords": [
    "monobank",
    "monobank-api",
    "ledger",
    "personal-finance",
    "finance",
    "finance-tracker",
    "local-first",
    "privacy",
    "banking",
    "banking-api",
    "typescript",
    "sqlite",
    "open-source",
    "ukraine"
  ],
  "author": "Andrii Furmanets",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/afurm/mono-ledger-sync.git"
  },
  "bugs": {
    "url": "https://github.com/afurm/mono-ledger-sync/issues"
  },
  "homepage": "https://github.com/afurm/mono-ledger-sync#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.8.5",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  }
}
